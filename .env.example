# Oniṣòwò — Environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).

# ============================================================
# TELEGRAM — Get this from @BotFather on Telegram
# ============================================================
# 1. Open Telegram
# 2. Search for @BotFather
# 3. Send /newbot
# 4. Choose a name (e.g., "My Oniṣòwò")
# 5. Choose a username (must end in "bot", e.g., "myasowo_bot")
# 6. BotFather will give you a token like: 123456:ABC-DEF...
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================
# BITGET — Get these from bitget.com → Account → API Management
# ============================================================
# 1. Log in to bitget.com
# 2. Click your face icon → API Management
# 3. Click "Create API Key"
# 4. Choose "System-generated"
# 5. Set permissions: Read + Trade (NEVER check Withdraw)
# 6. Set a strong passphrase
# 7. Bitget shows you 3 values ONCE — save them now
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# ============================================================
# QWEN LLM — Bitget hackathon gives you this in your inbox
# ============================================================
# 1. Check the email Bitget sent you
# 2. Find the Alibaba Cloud API key line
# 3. (Optional) Or use your own Alibaba Cloud key
QWEN_BASE_URL=https://hackathon.bitgetops.com/v1
BITGET_QWEN_API_KEY=your_qwen_key_here
QWEN_MODEL=qwen3.6-plus

# ============================================================
# OPTIONAL — Risk engine overrides (defaults scale with account)
# ============================================================
# Default max trade size is 25% of balance (percentage, not dollars).
# Default max drawdown kill switch is 30%.
# Default max daily loss is 30%.
# These can be overridden per-user via /settings max_trade_pct etc.
MAX_TRADE_PCT=0.25
MAX_POSITION_PCT=0.75
MAX_DRAWDOWN_PCT=0.30
MAX_DAILY_LOSS_PCT=0.30
LOG_LEVEL=INFO
DATABASE_PATH=./db/onisowo.db
